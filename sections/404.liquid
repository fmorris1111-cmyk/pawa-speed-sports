<div class="container-small">{% if section.settings.image_image %}
{{ section.settings.image_image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'image-6' }}
{% else %}
<img src="https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg" loading="lazy" alt="" class="image-6">
{% endif %}
          <div class="text-align-center">
            <div class="max-width-xlarge align-center">
              <div class="margin-bottom margin-small">
                <h1 class="heading-style-h1">
{{ section.settings.text_heading }}
</h1>
              </div>
              <p class="text-size-medium">
{{ section.settings.text_paragraph }}
</p>
              <div class="margin-top margin-medium">
                <div class="button-group is-center">
                  <a li-object:href="routes.root_url" href="{{ routes.root_url }}" class="button w-button"><span>
{{ section.settings.text_button_text }}
</span></a>
                </div>
              </div>
            </div>
          </div>
        </div> {% schema %} {
    "tag": "header",
    "name": "404",
    "class": "section_header",
    "settings": [
        {
            "id": "image_image",
            "type": "image_picker",
            "label": "IMAGE"
        },
        {
            "id": "text_heading",
            "type": "text",
            "label": "Heading",
            "default": "Page Not Found"
        },
        {
            "id": "text_paragraph",
            "type": "text",
            "label": "Paragraph",
            "default": "The page you are looking for doesn't exist or has been moved"
        },
        {
            "id": "text_button_text",
            "type": "text",
            "label": "Button Text",
            "default": "Back to Home"
        }
    ],
    "presets": [
        {
            "name": "404",
            "category": "Liquify",
            "blocks": []
        }
    ],
    "enabled_on": {
        "templates": [
            "404"
        ]
    }
} {% endschema %}